# Repo-root .dockerignore — the Dockerfile's build context is the repo root
# (it needs both api/ and panel/ to build the panel assets into api/public).

.git
.beads

api/vendor
api/node_modules
api/.env
api/.env.*
api/bootstrap/cache/*.php
api/storage/*.key
api/storage/framework/cache/*
api/storage/framework/sessions/*
api/storage/framework/views/*
api/storage/logs/*
api/public/panel-assets
api/.phpunit.cache
api/.phpunit.result.cache
api/tests
api/development-assets

panel/node_modules
panel/dist

platform
development-assets
*.md
!README.md
